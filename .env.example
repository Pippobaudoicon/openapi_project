# MongoDB Atlas connection
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# Session
SESSION_SECRET=your-session-secret

# OpenAI
OPENAI_API_KEY=sk-...

# OpenAPI/Altravia tokens
ACCESS_TOKEN_COMPANY=
ACCESS_TOKEN_VISURECAMERALI=

# OpenAPI/Altravia URLs
OPENAPI_COMPANY_URL=https://company.openapi.com
OPENAPI_VISURECAMERALI_URL=https://visurecamerali.openapi.it

# Application URLs (public-facing)
APP_URL=http://localhost:5173
SERVER_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=465
